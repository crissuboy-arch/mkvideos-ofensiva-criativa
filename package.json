{
  "name": "mkivideos",
  "version": "0.1.0",
  "description": "Motor portável de fila de vídeos (explicativo/curso/demo) — host-agnóstico, ports & adapters. Roda em qualquer jarvis (openpcbot, openclaw, hermes…) ou standalone.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sqlite-store": {
      "types": "./dist/sqlite-store.d.ts",
      "import": "./dist/sqlite-store.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
