{
  "name": "mkivideos",
  "version": "0.4.0",
  "description": "Motor universal de vídeos (offline): 7 tipos, 15 cenas, 7 marcas, 9:16/16:9, sync por áudio real — + Centro de Operações de Conteúdo (calendário, agendamento, contas, worker de publicação mock, lotes, logs). CLI + fila host-agnóstica.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mkivideos": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sqlite-store": {
      "types": "./dist/sqlite-store.d.ts",
      "import": "./dist/sqlite-store.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard.d.ts",
      "import": "./dist/dashboard.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "tsc"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
